---
title: "FASTag Toll System — Container Diagram (C4 Level 2)"
---
C4Container
    title FASTag Toll Optimization — Container Diagram

    Person(commuter, "Commuter", "FASTag vehicle")
    Person(operator, "Toll Operator", "Exception management")

    System_Boundary(edge, "Toll Plaza Edge (Per Plaza)") {
        Container(rfid_reader, "RFID Reader Array", "Hardware", "Reads FASTag RFID at 150m upstream. Dual-reader redundancy per lane.")
        Container(edge_processor, "Edge Processing Unit", "Java 21 / Spring Boot", "Correlates tag reads with loop sensor events. Publishes TagRead events. Manages local token cache.")
        Container(lane_controller, "Lane Controller Service", "Java 21 / Spring Boot", "Controls barrier arm. Validates pre-auth token. Emits BarrierOpened events.")
        ContainerDb(edge_cache, "Edge Redis Cache", "Redis 7", "Pre-auth tokens and balance cache for offline operation.")
    }

    System_Boundary(cloud, "Core Platform — Azure Kubernetes Service") {
        Container(api_gateway, "API Gateway", "Spring Cloud Gateway", "Single entry point for all inbound API calls. Enforces authentication, rate limiting, and routing.")
        Container(preauth_svc, "Pre-Auth Service", "Java 21 / Spring Boot", "Consumes TagRead events. Calls NPCI pre-authorization. Publishes PreAuthorizationApproved / Declined events.")
        Container(payment_svc, "Payment Service", "Java 21 / Spring Boot", "Handles settlement capture after barrier opens. Manages saga for pre-auth → capture lifecycle.")
        Container(fraud_svc, "Fraud Detection Service", "Java 21 / Spring Boot", "Geographic impossibility detection. ML-based velocity anomaly scoring. Publishes FraudSignal events.")
        Container(audit_svc, "Audit Service", "Java 21 / Spring Boot", "Append-only transaction record. Consumes all transaction events. No write access from other services.")
        Container(lane_mgmt_svc, "Lane Management Service", "Java 21 / Spring Boot", "Plaza and lane configuration. Express lane activation. Operator API.")
        Container(kafka, "Apache Kafka", "Kafka 3.x", "Durable event bus. Topics: tag.read, preauth.result, barrier.event, transaction.complete, fraud.signal, reader.health.")
        ContainerDb(postgres, "PostgreSQL", "PostgreSQL 15 HA", "Transactional store for payment records and audit log. Read replica for reporting queries.")
        ContainerDb(redis_cluster, "Redis Cluster", "Redis 7 Cluster", "Pre-auth token store. Session cache. Shared between cloud services.")
    }

    System_Boundary(intelligence, "Intelligence & Operations Platform") {
        Container(ops_dashboard, "Operator Dashboard", "React / HTTPS", "Real-time lane status, alert feed, AI assistant output, manual override controls.")
        Container(ai_ops, "AI Operations Assistant", "Java / Claude API", "Incident RCA. Runbook generation. Postmortem drafting. Advisory only.")
        Container(ml_platform, "ML Inference Services", "Azure ML / Python", "Reader failure prediction. Queue forecasting. Fraud scoring model.")
        Container(otel_collector, "OpenTelemetry Collector", "OTel Collector", "Receives traces, metrics, logs from all services. Exports to Dynatrace.")
        Container(dynatrace, "Dynatrace", "SaaS APM", "Distributed tracing, Davis AI anomaly detection, SLO tracking, dashboards.")
    }

    System_Ext(npci, "NPCI Payment Gateway", "External")

    Rel(commuter, rfid_reader, "Drives past", "RFID 915MHz")
    Rel(rfid_reader, edge_processor, "Tag read signal", "TCP/IP")
    Rel(edge_processor, kafka, "Publishes TagRead event", "Kafka / TLS")
    Rel(edge_processor, edge_cache, "Reads/writes auth tokens", "Redis protocol")
    Rel(lane_controller, edge_cache, "Validates pre-auth token", "Redis protocol")
    Rel(lane_controller, kafka, "Publishes BarrierOpened event", "Kafka / TLS")

    Rel(preauth_svc, kafka, "Consumes TagRead / publishes PreAuth result", "Kafka / TLS")
    Rel(preauth_svc, npci, "Pre-authorizes payment", "HTTPS / REST")
    Rel(preauth_svc, redis_cluster, "Stores auth token", "Redis protocol")

    Rel(payment_svc, kafka, "Consumes PreAuth + Barrier events / publishes Settlement", "Kafka / TLS")
    Rel(payment_svc, npci, "Settles payment capture", "HTTPS / REST")
    Rel(payment_svc, postgres, "Writes settlement record", "JDBC")

    Rel(fraud_svc, kafka, "Consumes TagRead + Transaction events", "Kafka / TLS")
    Rel(audit_svc, kafka, "Consumes all events / writes audit log", "Kafka / TLS")
    Rel(audit_svc, postgres, "Append-only audit write", "JDBC")

    Rel(operator, ops_dashboard, "Manages exceptions", "HTTPS")
    Rel(ops_dashboard, api_gateway, "API calls", "HTTPS")
    Rel(api_gateway, lane_mgmt_svc, "Routes lane management requests", "HTTP")

    Rel(ai_ops, dynatrace, "Reads incident telemetry", "Dynatrace API")
    Rel(ml_platform, kafka, "Consumes reader.health events", "Kafka / TLS")

    Rel(edge_processor, otel_collector, "Exports traces + metrics", "OTLP / gRPC")
    Rel(preauth_svc, otel_collector, "Exports traces + metrics", "OTLP / gRPC")
    Rel(otel_collector, dynatrace, "Exports telemetry", "OTLP")
