---
title: "FASTag — Future State Architecture Flow"
---
flowchart TD
    subgraph EDGE["Toll Plaza Edge"]
        direction TB
        RU["RFID Reader Array\n(150m upstream)"]
        LS1["Loop Sensor\n(150m)"]
        EP["Edge Processing Unit\n(Spring Boot)"]
        RC["Edge Redis Cache\n(tokens + balance)"]
        LC["Lane Controller"]
        LS2["Loop Sensor\n(at barrier)"]
        RG["RFID Reader\n(at barrier - fallback)"]
    end

    subgraph KAFKA["Apache Kafka — Event Bus"]
        direction LR
        T1["tag.read"]
        T2["preauth.result"]
        T3["barrier.event"]
        T4["transaction.complete"]
        T5["fraud.signal"]
        T6["reader.health"]
    end

    subgraph CLOUD["Core Platform — AKS"]
        direction TB
        PA["Pre-Auth Service"]
        PS["Payment Service"]
        FD["Fraud Detection Service"]
        AU["Audit Service"]
        LM["Lane Management Service"]
        GW["API Gateway\n(Spring Cloud Gateway)"]
        PG[("PostgreSQL\n(HA)")]
        RCC[("Redis Cluster\n(cloud)")]
    end

    subgraph INTEL["Intelligence Platform"]
        direction TB
        OPS["AI Operations Assistant\n(Claude API)"]
        ML["ML Inference\n(Azure ML)"]
        DT["Dynatrace\n(Traces · Metrics · Logs)"]
        DASH["Operator Dashboard"]
    end

    subgraph EXT["External Systems"]
        NPCI["NPCI Payment Gateway"]
        NHAI["NHAI Reporting"]
    end

    %% Edge flow
    RU -->|"Tag read signal"| EP
    LS1 -->|"Vehicle presence"| EP
    EP -->|"Check / store token"| RC
    EP -->|"TagRead event"| T1

    %% Pre-auth flow
    T1 -->|"Consume"| PA
    PA -->|"Pre-authorize"| NPCI
    NPCI -->|"Token + hold"| PA
    PA -->|"Store token"| RCC
    PA -->|"PreAuthApproved event"| T2

    %% Gate decision (< 2s after vehicle arrives)
    LS2 -->|"Vehicle at barrier"| LC
    LC -->|"Token lookup"| RC
    RC -->|"Token found ✓"| LC
    LC -->|"Barrier open signal"| LC
    LC -->|"BarrierOpened event"| T3

    %% Async settlement (not in critical path)
    T3 -->|"Consume"| PS
    PS -->|"Settlement capture"| NPCI
    PS -->|"Write record"| PG
    PS -->|"TransactionComplete event"| T4

    %% Fraud and Audit (async)
    T1 -->|"Consume"| FD
    T4 -->|"Consume"| FD
    FD -->|"FraudSignal event"| T5
    T5 -->|"Fraud alert"| DASH
    T5 -->|"Flag for review"| LM
    T3 -->|"Consume"| AU
    T4 -->|"Consume"| AU
    AU -->|"Append audit record"| PG

    %% Operator
    DASH -->|"API"| GW
    GW -->|"Route"| LM
    GW -->|"Route"| PA

    %% Intelligence
    DT -->|"Incident telemetry"| OPS
    T6 -->|"Consume"| ML
    ML -->|"Failure prediction"| DASH
    OPS -->|"RCA advisory"| DASH

    %% Reporting
    T4 -->|"Consume"| NHAI

    %% Observability
    EP -.->|"OTLP traces"| DT
    PA -.->|"OTLP traces"| DT
    PS -.->|"OTLP traces"| DT
    LC -.->|"OTLP traces"| DT

    classDef edge fill:#e8f4f8,stroke:#2980b9
    classDef cloud fill:#eafaf1,stroke:#27ae60
    classDef intel fill:#fef9e7,stroke:#f39c12
    classDef ext fill:#f9f9f9,stroke:#95a5a6
    classDef kafka fill:#fdf2f8,stroke:#8e44ad

    class RU,LS1,EP,RC,LC,LS2,RG edge
    class PA,PS,FD,AU,LM,GW,PG,RCC cloud
    class OPS,ML,DT,DASH intel
    class NPCI,NHAI ext
    class T1,T2,T3,T4,T5,T6 kafka
