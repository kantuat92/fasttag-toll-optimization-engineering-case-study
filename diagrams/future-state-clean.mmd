---
title: "FASTag — Future State Architecture"
---
flowchart LR

    %% ══════════════════════════════════════════════════════
    %%  ZONE 1 · EDGE  (Toll Plaza)
    %% ══════════════════════════════════════════════════════
    subgraph EDGE["  EDGE  ·  Toll Plaza  "]
        direction TB
        RDR["RFID Array\n◀ 150 m upstream"]
        EPU["Edge Processor\n+ Local Redis Cache"]
        LCT["Lane Controller\n+ Barrier"]
        OPEN{{"✓  Barrier Opens\n    < 2s after arrival"}}
        RDR -.->|"fallback\nreader at barrier"| LCT
    end

    %% ══════════════════════════════════════════════════════
    %%  ZONE 2 · CORE PLATFORM  (AKS)
    %% ══════════════════════════════════════════════════════
    subgraph PLATFORM["  CORE PLATFORM  ·  Azure Kubernetes Service  "]
        direction TB
        KAFKA[["Apache Kafka  —  Event Bus\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\ntag.read  ·  preauth.result  ·  barrier.event\ntransaction.complete  ·  fraud.signal  ·  reader.health"]]
        SVC["Pre-Auth  ·  Payment\nFraud Detection  ·  Audit\nLane Management"]
        STORE[("Redis Cluster\nPostgreSQL  HA")]
        KAFKA <-->|"consume / publish"| SVC
        SVC <--> STORE
    end

    %% ══════════════════════════════════════════════════════
    %%  ZONE 3 · INTELLIGENCE  &  OPERATIONS
    %% ══════════════════════════════════════════════════════
    subgraph INTEL["  INTELLIGENCE  &  OPERATIONS  "]
        direction TB
        DYN["Dynatrace\nDavis AI  ·  SLOs  ·  Tracing"]
        AIO["AI Ops Assistant\nClaude API"]
        MLS["ML Inference\nAzure ML"]
        ODB["Operator Dashboard"]
        DYN --> AIO --> ODB
        MLS --> ODB
    end

    %% ══════════════════════════════════════════════════════
    %%  EXTERNAL SYSTEMS
    %% ══════════════════════════════════════════════════════
    NPCI(["NPCI\nPayment Gateway"])
    NHAI(["NHAI\nReporting"])

    %% ══════════════════════════════════════════════════════
    %%  CRITICAL PATH  ①–⑧  (solid, numbered)
    %%  Vehicle processes in < 30 seconds end-to-end
    %% ══════════════════════════════════════════════════════
    RDR     -- "① Tag read"           --> EPU
    EPU     -- "② TagRead event"      --> KAFKA
    KAFKA   -- "③ Pre-Auth consumes"  --> SVC
    SVC     -- "④ Pre-authorize"      --> NPCI
    NPCI    -- "⑤ Token + hold"       --> SVC
    SVC     -- "⑥ Token cached"       --> STORE
    STORE  -. "⑦ Token synced\nto edge" .-> EPU
    EPU     -- "⑧ Token lookup"       --> LCT
    LCT     -- "Barrier opens"        --> OPEN

    %% ══════════════════════════════════════════════════════
    %%  ASYNC FLOWS  (dashed — not in gate critical path)
    %% ══════════════════════════════════════════════════════
    LCT  -.->|"BarrierOpened"| KAFKA
    SVC  -.->|"settlement capture"| NPCI
    KAFKA-.->|"txn.complete"| NHAI
    KAFKA-.->|"fraud.signal → alert"| ODB

    %% ══════════════════════════════════════════════════════
    %%  OBSERVABILITY  (dotted)
    %% ══════════════════════════════════════════════════════
    EPU  -. "OTLP" .-> DYN
    SVC  -. "OTLP" .-> DYN
    LCT  -. "OTLP" .-> DYN
    KAFKA-.->|"reader.health"| MLS

    %% ══════════════════════════════════════════════════════
    %%  LEGEND
    %% ══════════════════════════════════════════════════════
    subgraph LEGEND["  Legend  "]
        direction TB
        LA["━━━▶  Critical path  (gate decision)"]
        LB["╌╌╌▶  Async flow  (post-passage)"]
        LC2["┄┄┄▶  Observability  (OTLP / telemetry)"]
    end

    %% ══════════════════════════════════════════════════════
    %%  STYLES
    %% ══════════════════════════════════════════════════════
    classDef edge    fill:#dbeafe,stroke:#2563eb,color:#1e3a8a,font-weight:bold
    classDef kafka   fill:#ede9fe,stroke:#7c3aed,color:#4c1d95,font-weight:bold
    classDef service fill:#dcfce7,stroke:#15803d,color:#14532d
    classDef store   fill:#fef9c3,stroke:#b45309,color:#78350f
    classDef intel   fill:#fff7ed,stroke:#c2410c,color:#7c2d12
    classDef ext     fill:#f1f5f9,stroke:#64748b,color:#334155
    classDef legend  fill:#f8fafc,stroke:#cbd5e1,color:#64748b,font-size:12px

    class RDR,EPU,LCT,OPEN edge
    class KAFKA kafka
    class SVC service
    class STORE store
    class DYN,AIO,MLS,ODB intel
    class NPCI,NHAI ext
    class LA,LB,LC2 legend
